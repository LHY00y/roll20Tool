{
  "manifest_version": 2,
  "name": "Tools for roll20",
  "version": "1.0.0",
  "description": "상용구 정리",
  "sidebar_action": {
    "default_page": "sidebar.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "TypeSaver",
    "use_navigation_bar": false
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "storage",
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}